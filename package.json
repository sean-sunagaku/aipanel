{
  "name": "aipanel-cli",
  "version": "0.2.0",
  "description": "CLI broker and orchestrator for consult, followup, and debug workflows with Claude Code and Codex.",
  "private": false,
  "license": "MIT",
  "keywords": [
    "cli",
    "claude-code",
    "codex",
    "broker",
    "orchestrator",
    "debugging"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sean-sunagaku/aipanel.git"
  },
  "bugs": {
    "url": "https://github.com/sean-sunagaku/aipanel/issues"
  },
  "homepage": "https://github.com/sean-sunagaku/aipanel#readme",
  "type": "module",
  "bin": {
    "aipanel": "dist/bin/aipanel.js"
  },
  "exports": {
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.28.0",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "node scripts/clean-dist.mjs",
    "build": "node scripts/clean-dist.mjs && tsc -p tsconfig.build.json",
    "dev": "tsx bin/aipanel.ts",
    "start": "node dist/bin/aipanel.js",
    "worktree:add": "node scripts/add-worktree.mjs",
    "worktree:list": "git worktree list",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "fmt": "prettier . --write",
    "fmt:check": "prettier . --check",
    "check:agent-skills": "node scripts/validate-agent-skills.mjs",
    "check:docs": "node scripts/lint/check-doc-comments.mjs",
    "check:usage": "node scripts/lint/generate-symbol-context.mjs --fail-on-delete-now",
    "docs:context": "node scripts/lint/generate-symbol-context.mjs",
    "smoke": "pnpm run build && node dist/bin/aipanel.js providers --json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "audit": "pnpm audit --audit-level=low",
    "render:diagrams": "node scripts/architecture/render-diagram-bundle.mjs docs/rearchitecture/content_rearchitecture_2026-03-10/12_current-implementation-diagrams/source/current-implementation-diagrams.spec.json docs/rearchitecture/content_rearchitecture_2026-03-10/12_current-implementation-diagrams",
    "pack:dry-run": "pnpm pack --dry-run",
    "verify:package": "node scripts/verify-package-install.mjs",
    "publish:check": "pnpm run typecheck && pnpm test && pnpm run pack:dry-run && pnpm run verify:package",
    "publish:public": "pnpm run publish:check && pnpm publish --access public",
    "prepack": "pnpm run build",
    "test:unit": "tsx --test $(find test/unit -name '*.test.ts' -print)",
    "test:integration": "pnpm run build && tsx --test $(find test/integration -name '*.test.ts' -print)",
    "test:e2e": "pnpm run build && tsx --test $(find test/e2e -name '*.test.ts' -print)",
    "test": "pnpm run test:unit && pnpm run test:integration && pnpm run test:e2e"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/node": "^24.0.0",
    "eslint": "^9.22.0",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "ts-morph": "^27.0.2",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.26.1"
  }
}
